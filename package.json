{
  "name": "expense-tracker",
  "version": "0.1.0",
  "private": true,
  "description": "Offline-first PWA expense tracker for a two-person household (Firestore + Anonymous Auth, AWS Amplify static hosting).",
  "scripts": {
    "dev": "next dev",
    "dev:lan": "powershell -ExecutionPolicy Bypass -File start-lan.ps1",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "firebase": "^10.13.2",
    "next": "^14.2.15",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.47.2",
    "@types/node": "^20.16.10",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.1",
    "eslint-config-next": "^14.2.15",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.13",
    "typescript": "^5.6.2",
    "vitest": "^2.1.2"
  }
}
